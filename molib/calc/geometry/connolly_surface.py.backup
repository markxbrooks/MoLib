"""
Connolly surface calculation for molecular visualization.

A Connolly surface (also known as molecular surface or solvent-accessible surface)
is generated by rolling a probe sphere over the van der Waals surface of atoms.
"""

import math
from typing import Tuple

import numpy as np
from scipy.sparse import csr_matrix
from scipy.sparse.csgraph import laplacian
from scipy.spatial.distance import cdist
from skimage import measure  # skimage.measure.marching_cubes

from decologr.logger import Decologr as log


def smooth_surface(
    vertices: np.ndarray, faces: np.ndarray, iterations: int = 1
) -> np.ndarray:
    """
    Apply Laplacian smoothing to surface vertices for better quality.

    Args:
        vertices: Surface vertices (N, 3)
        faces: Surface faces (M, 3)
        iterations: Number of smoothing iterations

    Returns:
        Smoothed vertices (N, 3)
    """
    if len(vertices) == 0 or len(faces) == 0:
        return vertices

    smoothed_vertices = vertices.copy()

    for _ in range(iterations):
        # Build adjacency matrix
        n_vertices = len(vertices)
        adj_matrix = np.zeros((n_vertices, n_vertices), dtype=bool)

        # For each face, mark adjacent vertices
        for face in faces:
            i, j, k = face
            adj_matrix[i, j] = adj_matrix[j, i] = True
            adj_matrix[i, k] = adj_matrix[k, i] = True
            adj_matrix[j, k] = adj_matrix[k, j] = True

        # Apply Laplacian smoothing: new_pos = average of neighbors
        new_vertices = smoothed_vertices.copy()
        for i in range(n_vertices):
            neighbors = np.where(adj_matrix[i])[0]
            if len(neighbors) > 0:
                new_vertices[i] = np.mean(smoothed_vertices[neighbors], axis=0)

        smoothed_vertices = new_vertices

    return smoothed_vertices


def calculate_connolly_surface(
    atom_positions: np.ndarray,
    atom_radii: np.ndarray,
    probe_radius: float = 1.4,
    grid_spacing: float = 0.5,
    density: float = 1.0,
    padding: float = 5.0,
    smoothing: bool = True,
    progress_callback=None,
) -> Tuple[np.ndarray, np.ndarray, np.ndarray]:
    """
    Calculate Connolly surface (approx) using a signed distance field + marching cubes.

    Key optimizations:
      * build a tight grid around the molecule
      * for each atom, only evaluate the subgrid inside the atom+probe bounding box
      * work with squared distances and compute sqrt only where needed

    Returns (vertices, faces, normals). On failure returns (np.array([]), np.array([]), np.array([])).
    """

    # Check cache first to prevent race conditions
    cached_result = _get_cached_connolly_surface(
        atom_positions, atom_radii, probe_radius, grid_spacing, density, padding, smoothing
    )
    if cached_result is not None:
        return cached_result
    
    
        # Parameter validation to prevent unnecessary recalculations
        if atom_positions.size == 0:
            log.debug("Empty atom positions, returning empty surface")
            return np.array([]), np.array([]), np.array([])
        
        if len(atom_positions) != len(atom_radii):
            log.warning(f"Mismatch between atom positions ({len(atom_positions)}) and radii ({len(atom_radii)})")
            return np.array([]), np.array([]), np.array([])
        
        # Check for invalid parameters that could cause repeated calculations
        if probe_radius <= 0:
            log.warning(f"Invalid probe radius: {probe_radius}, using default 1.4")
            probe_radius = 1.4
        
        if grid_spacing <= 0:
            log.warning(f"Invalid grid spacing: {grid_spacing}, using default 0.5")
            grid_spacing = 0.5
        
        log.debug(f"Connolly surface calculation starting with {len(atom_positions)} atoms")
        
        try:
            if atom_positions.size == 0:
                return np.array([]), np.array([]), np.array([])

            # bounding box including radii + probe
            min_coords = np.min(atom_positions - atom_radii[:, None] - probe_radius, axis=0)
            max_coords = np.max(atom_positions + atom_radii[:, None] + probe_radius, axis=0)

            # optional extra padding for better marching-cubes quality
            min_coords -= padding
            max_coords += padding

            # Create grid axes using arange (safer than linspace for spacing)
            # ensure we include max_coords by adding a tiny epsilon
            eps = 1e-9
            xs = np.arange(
            min_coords[0], max_coords[0] + eps, grid_spacing, dtype=np.float32
            )
            ys = np.arange(
            min_coords[1], max_coords[1] + eps, grid_spacing, dtype=np.float32
            )
            zs = np.arange(
            min_coords[2], max_coords[2] + eps, grid_spacing, dtype=np.float32
            )

            nx, ny, nz = len(xs), len(ys), len(zs)
            log.info(f"🔬 Grid size: {nx} x {ny} x {nz} -> total {nx * ny * nz:,} points")

            # Report progress: Grid setup complete
            if progress_callback:
                progress_callback(10, 100, "Setting up grid...")

            # initialize signed distance field to +inf (outside)
            distance_field = np.full((nx, ny, nz), np.inf, dtype=np.float32)

            # precompute grid coordinates for slicing convenience
            # We'll construct local subgrids with meshgrid on slices per atom
            grid_origin = min_coords.copy()

            # helper: clamp indices to grid bounds
            def clamp_indices(a, low, high):
                a = int(a)
                if a < low:
                    return low
                if a > high:
                    return high
                return a

            n_atoms = atom_positions.shape[0]
        
            # Report progress: Starting atom processing
            if progress_callback:
            progress_callback(20, 100, f"Processing {n_atoms} atoms...")
        
            for i, (pos, radius) in enumerate(zip(atom_positions, atom_radii)):
            # expanded radius (atom + probe)
            expanded = float(radius) + float(probe_radius)
            expanded_sq = expanded * expanded

            # compute integer index range for bounding box (inclusive)
            min_idx_f = (pos - expanded - grid_origin) / grid_spacing
            max_idx_f = (pos + expanded - grid_origin) / grid_spacing

            ix0 = max(0, math.floor(min_idx_f[0]))
            iy0 = max(0, math.floor(min_idx_f[1]))
            iz0 = max(0, math.floor(min_idx_f[2]))

            ix1 = min(nx - 1, math.ceil(max_idx_f[0]))
            iy1 = min(ny - 1, math.ceil(max_idx_f[1]))
            iz1 = min(nz - 1, math.ceil(max_idx_f[2]))

            # if bounding box is empty skip
            if ix1 < ix0 or iy1 < iy0 or iz1 < iz0:
                continue

            # slice arrays for the local subgrid
            sub_x = xs[ix0 : ix1 + 1]
            sub_y = ys[iy0 : iy1 + 1]
            sub_z = zs[iz0 : iz1 + 1]

            # create mesh of coordinates for this small region
            # resulting shape (sx, sy, sz, 3)
            SX, SY, SZ = np.meshgrid(sub_x, sub_y, sub_z, indexing="ij")
            # compute squared distance to atom center
            dx = SX - pos[0]
            dy = SY - pos[1]
            dz = SZ - pos[2]
            sq_dist = dx * dx + dy * dy + dz * dz

            # mask points inside expanded radius -> only there we need sqrt
            inside_mask = sq_dist <= expanded_sq
            if not np.any(inside_mask):
                # nothing inside this atom's influence
                if i % 100 == 0:
                    log.info(f"🔬 Processed {i + 1}/{n_atoms} atoms (no overlap region)")
                continue

            # compute distances only where necessary
            local_dist = np.empty_like(sq_dist, dtype=np.float32)
            # default: sqrt for inside, else sqrt value (we only need distances for min calculation)
            # compute sqrt on masked elements, fill the rest with sqrt(sq_dist) too OR large value
            # but since for outside points distance - expanded will be > 0, we only need actual distances to compute distance - expanded
            # we'll compute sqrt only on mask, and set others to a large number
            local_dist.fill(np.inf)
            local_dist[inside_mask] = np.sqrt(sq_dist[inside_mask], dtype=np.float32)

            # compute signed distance = distance_to_surface - expanded_radius
            local_signed = local_dist - expanded  # shape (sx,sy,sz)

            # update the global distance field in the same slice with elementwise minimum
            # careful about shapes: local_signed aligns with [ix0:ix1+1, iy0:iy1+1, iz0:iz1+1]
            prev_slice = distance_field[ix0 : ix1 + 1, iy0 : iy1 + 1, iz0 : iz1 + 1]
            # take elementwise minimum
            np.minimum(prev_slice, local_signed, out=prev_slice)
            # write back the updated slice
            distance_field[ix0 : ix1 + 1, iy0 : iy1 + 1, iz0 : iz1 + 1] = prev_slice

            if (i + 1) % 100 == 0 or i == n_atoms - 1:
                log.info(f"🔬 Processed {i + 1}/{n_atoms} atoms")
                # Report progress: Atom processing (20-70% of total progress)
                if progress_callback:
                    atom_progress = 20 + int(50 * (i + 1) / n_atoms)
                    progress_callback(atom_progress, 100, f"Processing atoms... {i + 1}/{n_atoms}")

            # apply density scaling (shrinks/expands surface)
            if density != 1.0:
            distance_field = distance_field * float(density)

            # Report progress: Atom processing complete, starting marching cubes
            if progress_callback:
            progress_callback(70, 100, "Extracting surface...")

            # marching cubes: extract zero level (boundary)
            log.info("🔬 Extracting isosurface using marching_cubes...")
        try:
            verts, faces, normals, _ = measure.marching_cubes(
                distance_field,
                level=0.0,
                spacing=(grid_spacing, grid_spacing, grid_spacing),
                gradient_direction="ascent",  # Better normal calculation
                step_size=1,  # Process every voxel for maximum quality
                allow_degenerate=False,  # Avoid degenerate triangles
            )
            # marching_cubes returns vertices in grid coordinates (i,j,k)*spacing; convert to world coords
            verts += grid_origin  # broadcast addition

            # Apply smoothing if enabled
            if smoothing and len(verts) > 0:
                log.info("🔬 Applying surface smoothing...")
                # Report progress: Starting smoothing
                if progress_callback:
                    progress_callback(85, 100, "Smoothing surface...")
                
                verts = smooth_surface(verts, faces, iterations=1)
                # Recompute normals after smoothing
                from picogl.renderer.meshdata import compute_vertex_normals

                normals = compute_vertex_normals(verts, faces)

            log.info(
                f"✅ Connolly surface generated: {len(verts)} vertices, {len(faces)} faces"
            )
            
            # Report progress: Surface generation complete
            if progress_callback:
                progress_callback(100, 100, "Surface generation complete!")
            
            return (
                verts.astype(np.float32),
                faces.astype(np.int32),
                normals.astype(np.float32),
            )
            except Exception as e:
            log.warning(
                f"marching_cubes failed at level 0.0: {e}. Trying small fallback level 0.1"
            )
            try:
                verts, faces, normals, _ = measure.marching_cubes(
                    distance_field,
                    level=0.1,
                    spacing=(grid_spacing, grid_spacing, grid_spacing),
                    gradient_direction="ascent",
                    step_size=1,
                    allow_degenerate=False,
                )
                verts += grid_origin

                # Apply smoothing if enabled
                if smoothing and len(verts) > 0:
                    log.info("🔬 Applying surface smoothing (fallback)...")
                    # Report progress: Starting smoothing (fallback)
                    if progress_callback:
                        progress_callback(85, 100, "Smoothing surface...")
                    
                    verts = smooth_surface(verts, faces, iterations=1)
                    # Recompute normals after smoothing
                    from picogl.renderer.meshdata import compute_vertex_normals

                    normals = compute_vertex_normals(verts, faces)

                log.info(
                    f"✅ Connolly surface generated (fallback): {len(verts)} vertices, {len(faces)} faces"
                )
                
                # Report progress: Surface generation complete (fallback)
                if progress_callback:
                    progress_callback(100, 100, "Surface generation complete!")
                
                return (
                    verts.astype(np.float32),
                    faces.astype(np.int32),
                    normals.astype(np.float32),
                )
            except Exception as e2:
                log.error(f"Fallback marching_cubes failed: {e2}")
                return np.array([]), np.array([]), np.array([])

    except Exception as ex:
        log.error(f"❌ Error calculating Connolly surface: {ex}")
        return np.array([]), np.array([]), np.array([])


def get_atom_radii_from_elements(elements: list[str]) -> np.ndarray:
    """
    Get van der Waals radii for atoms based on their element symbols.

    Args:
        elements: List of element symbols (e.g., ['C', 'N', 'O', 'S'])

    Returns:
        Array of van der Waals radii in Å
    """
    # Van der Waals radii in Å (from various sources)
    vdw_radii = {
        "H": 1.20,
        "C": 1.70,
        "N": 1.55,
        "O": 1.52,
        "F": 1.47,
        "P": 1.80,
        "S": 1.80,
        "CL": 1.75,
        "BR": 1.85,
        "I": 1.98,
        "FE": 2.00,
        "ZN": 1.39,
        "CA": 2.31,
        "MG": 1.73,
        "NA": 2.27,
        "K": 2.75,
        "CU": 1.40,
        "MN": 1.61,
        "CO": 1.63,
        "NI": 1.63,
        "SE": 1.90,
        "AS": 1.85,
        "TE": 2.06,
        "SB": 2.06,
        "BI": 2.07,
        "PD": 1.63,
        "PT": 1.75,
        "AU": 1.66,
        "AG": 1.72,
        "CD": 1.58,
        "HG": 1.55,
        "TL": 1.96,
        "PB": 2.02,
        "SN": 2.17,
        "GE": 2.11,
        "SI": 2.10,
        "B": 1.92,
        "AL": 1.84,
        "GA": 1.87,
        "IN": 1.93,
        "TI": 2.00,
        "V": 1.53,
        "CR": 1.39,
        "MO": 1.54,
        "W": 1.37,
        "TA": 1.43,
        "RE": 1.37,
        "OS": 1.37,
        "IR": 1.32,
        "RU": 1.46,
        "RH": 1.46,
        "TC": 1.54,
        "LA": 2.07,
        "CE": 2.04,
        "PR": 2.03,
        "ND": 2.01,
        "PM": 1.99,
        "SM": 1.98,
        "EU": 1.98,
        "GD": 1.96,
        "TB": 1.94,
        "DY": 1.92,
        "HO": 1.92,
        "ER": 1.89,
        "TM": 1.90,
        "YB": 1.87,
        "LU": 1.87,
        "AC": 2.15,
        "TH": 2.06,
        "PA": 2.00,
        "U": 1.86,
        "NP": 1.75,
        "PU": 1.75,
        "AM": 1.75,
        "CM": 1.75,
        "BK": 1.75,
        "CF": 1.75,
        "ES": 1.75,
        "FM": 1.75,
        "MD": 1.75,
        "NO": 1.75,
        "LR": 1.75,
        "RF": 1.75,
        "DB": 1.75,
        "SG": 1.75,
        "BH": 1.75,
        "HS": 1.75,
        "MT": 1.75,
        "DS": 1.75,
        "RG": 1.75,
        "CN": 1.75,
        "NH": 1.75,
        "FL": 1.75,
        "MC": 1.75,
        "LV": 1.75,
        "TS": 1.75,
        "OG": 1.75,
    }

    radii = []
    for element in elements:
        element_upper = element.upper().strip()
        if element_upper in vdw_radii:
            radii.append(vdw_radii[element_upper])
        else:
            # Default radius for unknown elements
            log.warning(f"⚠️ Unknown element '{element}', using default radius 1.5 Å")
            radii.append(1.5)

    return np.array(radii)


def calculate_connolly_surface_from_molecule(
    molecule,
    probe_radius: float = 1.4,
    grid_spacing: float = 0.5,
    density: float = 1.0,
    padding: float = 5.0,
    smoothing: bool = True,
    progress_callback=None,
) -> tuple[np.ndarray, np.ndarray, np.ndarray]:
    """
    Calculate Connolly surface from a Molecule3D object.

    Args:
        molecule: Molecule3D object
        probe_radius: Radius of probe sphere in Å
        grid_spacing: Grid resolution in Å
        density: Density multiplier for surface generation
        padding: Extra padding around molecule in Å
        smoothing: Whether to apply surface smoothing
        progress_callback: Optional callback function for progress updates (value, max_value, message)

    Returns:
        tuple: (vertices, faces, normals) - surface mesh data
    """
    log.info("🔬 Calculating Connolly surface from molecule")

    try:
            # Collect all atom positions and elements
            atom_positions = []
            elements = []

            for model in molecule.models:
            for chain in model.chains.values():
                for residue in chain.residues:
                    for atom in residue.atoms.values():
                        atom_positions.append(atom.pos)
                        elements.append(atom.element)

            if not atom_positions:
            log.warning("⚠️ No atoms found in molecule")
            return np.array([]), np.array([]), np.array([])

            atom_positions = np.array(atom_positions)
            atom_radii = get_atom_radii_from_elements(elements)

            log.info(f"🔬 Found {len(atom_positions)} atoms")

            return calculate_connolly_surface(
            atom_positions,
            atom_radii,
            probe_radius,
            grid_spacing,
            density,
            padding,
            smoothing,
            progress_callback,
            )

    except Exception as ex:
        log.error(f"❌ Error calculating Connolly surface from molecule: {ex}")
        return np.array([]), np.array([]), np.array([])


def create_connolly_surface_colors(
    vertices: np.ndarray,
    color_scheme: str = "uniform",
    atom_positions: np.ndarray = None,
    atom_colors: np.ndarray = None,
    uniform_color: tuple = None,
) -> np.ndarray:
    """
    Create RGB colors for Connolly surface vertices.
    Transparency is handled by the rendering pipeline, not in the colors.

    Args:
        vertices: Surface vertices (N, 3)
        color_scheme: Color scheme ("uniform", "height", "distance", "atom")
        atom_positions: Atom positions (M, 3) for atom-based coloring
        atom_colors: Atom colors (M, 3) for atom-based coloring

    Returns:
        Array of RGB colors (N, 3)
    """
    if len(vertices) == 0:
        return np.array([])

    if color_scheme == "uniform":
        # Use provided uniform color or default blue
        if uniform_color is not None:
            return np.full((len(vertices), 3), uniform_color)
        else:
            # Default blue colour for Connolly surface
            return np.full((len(vertices), 3), [0.2, 0.6, 1.0])

    elif color_scheme == "height":
        # Color by Z-coordinate (height)
        z_coords = vertices[:, 2]
        z_min, z_max = z_coords.min(), z_coords.max()
        if z_max > z_min:
            normalized_z = (z_coords - z_min) / (z_max - z_min)
            # Blue to red gradient
            colors = np.zeros((len(vertices), 3))
            colors[:, 0] = normalized_z  # Red component
            colors[:, 2] = 1.0 - normalized_z  # Blue component
            return colors
        else:
            return np.full((len(vertices), 3), [0.2, 0.6, 1.0])

    elif color_scheme == "distance":
        # Color by distance from origin
        distances = np.linalg.norm(vertices, axis=1)
        d_min, d_max = distances.min(), distances.max()
        if d_max > d_min:
            normalized_d = (distances - d_min) / (d_max - d_min)
            # Green to purple gradient
            colors = np.zeros((len(vertices), 3))
            colors[:, 1] = 1.0 - normalized_d  # Green component
            colors[:, 2] = normalized_d  # Blue component
            return colors
        else:
            return np.full((len(vertices), 3), [0.2, 0.6, 1.0])

    elif (
        color_scheme == "atom"
        and atom_positions is not None
        and atom_colors is not None
    ):
        # Check if atom data is empty
        if len(atom_positions) == 0 or len(atom_colors) == 0:
            log.debug(
                "Atom coloring - Empty atom data, falling back to uniform coloring"
            )
            return np.full((len(vertices), 3), [0.2, 0.6, 1.0])

        # Debug: Check spatial distribution
        log.debug(
            f"Atom coloring - Vertices range: min={vertices.min(axis=0)}, max={vertices.max(axis=0)}"
        )
        log.debug(
            f"Atom coloring - Atom positions range: min={atom_positions.min(axis=0)}, max={atom_positions.max(axis=0)}"
        )
        log.debug(
            f"Atom coloring - Unique atom colors: {len(np.unique(atom_colors, axis=0))}"
        )

        # Color by nearest atom
        colors = _color_by_nearest_atom(vertices, atom_positions, atom_colors)
        return colors

    else:
        # Default uniform colour
        return np.full((len(vertices), 3), [0.2, 0.6, 1.0])


def _color_by_nearest_atom(
    vertices: np.ndarray, atom_positions: np.ndarray, atom_colors: np.ndarray
) -> np.ndarray:
    """
    Color Connolly surface vertices by their nearest atom.
    Optimized version using spatial indexing for better performance.

    Args:
        vertices: Surface vertices (N, 3)
        atom_positions: Atom positions (M, 3)
        atom_colors: Atom colors (M, 3)

    Returns:
        Array of RGB colors (N, 3)
    """
    if len(atom_positions) == 0 or len(atom_colors) == 0:
        return np.full((len(vertices), 3), [0.2, 0.6, 1.0])

    # For small numbers of atoms or vertices, use the simple approach
    if len(atom_positions) < 500 or len(vertices) < 1000:
        return _color_by_nearest_atom_simple(vertices, atom_positions, atom_colors)

    # For larger datasets, use spatial indexing
    return _color_by_nearest_atom_spatial(vertices, atom_positions, atom_colors)


def _color_by_nearest_atom_simple(
    vertices: np.ndarray, atom_positions: np.ndarray, atom_colors: np.ndarray
) -> np.ndarray:
    """
    Simple O(N×M) implementation for small datasets.
    """
    # Calculate distances from each vertex to all atoms
    distances = np.linalg.norm(
        vertices[:, np.newaxis, :] - atom_positions[np.newaxis, :, :], axis=2
    )

    # Find nearest atom for each vertex
    nearest_atom_indices = np.argmin(distances, axis=1)

    # Debug: Check which atoms are being selected
    from collections import Counter

    nearest_atom_counts = Counter(nearest_atom_indices)
    log.debug(
        f"Simple algorithm - Nearest atom selection: {dict(nearest_atom_counts.most_common(10))}"
    )

    # Show a more representative sample of indices
    sample_indices = nearest_atom_indices[:: max(1, len(nearest_atom_indices) // 10)]
    log.debug(f"Simple algorithm - Sample nearest atom indices: {sample_indices}")
    log.debug(f"Simple algorithm - Sample atom colors: {atom_colors[sample_indices]}")

    # Check unique atoms selected
    unique_selected = np.unique(nearest_atom_indices)
    log.debug(
        f"Simple algorithm - Unique atoms selected: {len(unique_selected)} out of {len(atom_positions)} total atoms"
    )

    # Debug: Check if all selected atoms have the same colour
    selected_colors = atom_colors[nearest_atom_indices]
    unique_colors = np.unique(selected_colors, axis=0)
    log.debug(
        f"Simple algorithm - Unique colors in selected atoms: {len(unique_colors)}"
    )
    if len(unique_colors) < 10:
        log.debug(f"Simple algorithm - Selected colors: {unique_colors}")

    # Get colors for nearest atoms
    colors = atom_colors[nearest_atom_indices]

    return colors


def _color_by_nearest_atom_spatial(
    vertices: np.ndarray, atom_positions: np.ndarray, atom_colors: np.ndarray
) -> np.ndarray:
    """
    Optimized implementation using spatial indexing for large datasets.
    Uses a grid-based approach to reduce the search space.
    """
    log.debug(
        f"Using spatial atom coloring: {len(vertices)} vertices, {len(atom_positions)} atoms"
    )

    # Try to get cached spatial index
    atom_tree, cached_colors = _get_cached_spatial_index(atom_positions, atom_colors)

    if atom_tree is not None:
        # Use cached spatial index
        _, nearest_atom_indices = atom_tree.query(vertices)

        # Debug: Check which atoms are being selected
        from collections import Counter

        nearest_atom_counts = Counter(nearest_atom_indices)
        log.debug(
            f"Nearest atom selection (spatial): {dict(nearest_atom_counts.most_common(10))}"
        )

        # Show a more representative sample of indices (every 1000th vertex)
        sample_indices = nearest_atom_indices[
            :: max(1, len(nearest_atom_indices) // 10)
        ]
        log.debug(f"Sample nearest atom indices (every 1000th): {sample_indices}")
        log.debug(f"Sample atom colors: {cached_colors[sample_indices]}")

        # Debug: Check the most selected atom's position and colour
        most_selected_atom_idx = nearest_atom_counts.most_common(1)[0][0]
        log.debug(
            f"Most selected atom {most_selected_atom_idx}: position={atom_positions[most_selected_atom_idx]}, colour={cached_colors[most_selected_atom_idx]}"
        )

        # Debug: Check if all selected atoms have the same colour
        selected_colors = cached_colors[nearest_atom_indices]
        unique_colors = np.unique(selected_colors, axis=0)
        log.debug(f"Unique colors in selected atoms: {len(unique_colors)}")
        if len(unique_colors) < 10:
            log.debug(f"Selected colors: {unique_colors}")

        # Debug: Check if all selected atoms are the same
        unique_selected = np.unique(nearest_atom_indices)
        log.debug(
            f"Unique selected atom indices: {len(unique_selected)} out of {len(atom_positions)} total atoms"
        )
        if len(unique_selected) < 10:
            log.debug(f"Selected atom indices: {unique_selected}")

        # Check if spatial indexing is too focused on one atom
        # Use a more lenient threshold - if we're selecting fewer than 1% of available atoms, fall back
        min_unique_atoms = max(5, len(atom_positions) // 100)
        if len(unique_selected) < min_unique_atoms:
            log.warning(
                f"⚠️ Spatial indexing selected only {len(unique_selected)} unique atoms (threshold: {min_unique_atoms}), falling back to simple algorithm"
            )
            log.debug(f"Unique atom indices selected: {sorted(unique_selected)}")
            log.debug(
                f"Atom position range: min={atom_positions.min(axis=0)}, max={atom_positions.max(axis=0)}"
            )
            log.debug(
                f"Vertex position range: min={vertices.min(axis=0)}, max={vertices.max(axis=0)}"
            )
            return _color_by_nearest_atom_simple(vertices, atom_positions, atom_colors)

        colors = cached_colors[nearest_atom_indices]
        return colors
    else:
        # Fallback to simple implementation if scipy is not available
        log.debug("Falling back to simple atom coloring")
        return _color_by_nearest_atom_simple(vertices, atom_positions, atom_colors)



# Global cache for Connolly surface calculations to prevent race conditions
_connolly_surface_cache = {}
_cache_hits = 0
_cache_misses = 0

def _get_cache_key(atom_positions, atom_radii, probe_radius, grid_spacing, density, padding, smoothing):
    """Generate a cache key for Connolly surface parameters."""
    # Create a hash of the parameters that affect the surface calculation
    key_data = {
        'atom_positions': atom_positions.tobytes() if atom_positions.size > 0 else b'',
        'atom_radii': atom_radii.tobytes() if atom_radii.size > 0 else b'',
        'probe_radius': probe_radius,
        'grid_spacing': grid_spacing,
        'density': density,
        'padding': padding,
        'smoothing': smoothing
    }
    
    # Create a hash of the key data
    key_string = str(sorted(key_data.items()))
    return hashlib.md5(key_string.encode()).hexdigest()

def _get_cached_connolly_surface(atom_positions, atom_radii, probe_radius, grid_spacing, density, padding, smoothing):
    """Get cached Connolly surface if available."""
    global _cache_hits, _cache_misses
    
    cache_key = _get_cache_key(atom_positions, atom_radii, probe_radius, grid_spacing, density, padding, smoothing)
    
    if cache_key in _connolly_surface_cache:
        _cache_hits += 1
        log.debug(f"Connolly surface cache HIT ({_cache_hits} hits, {_cache_misses} misses)")
        return _connolly_surface_cache[cache_key]
    
    _cache_misses += 1
    log.debug(f"Connolly surface cache MISS ({_cache_hits} hits, {_cache_misses} misses)")
    return None

def _cache_connolly_surface(atom_positions, atom_radii, probe_radius, grid_spacing, density, padding, smoothing, result):
    """Cache Connolly surface result."""
    cache_key = _get_cache_key(atom_positions, atom_radii, probe_radius, grid_spacing, density, padding, smoothing)
    _connolly_surface_cache[cache_key] = result
    
    # Limit cache size to prevent memory issues
    if len(_connolly_surface_cache) > 10:
        # Remove oldest entries (simple FIFO)
        oldest_key = next(iter(_connolly_surface_cache))
        del _connolly_surface_cache[oldest_key]

def clear_connolly_surface_cache():
    """Clear the Connolly surface cache."""
    global _connolly_surface_cache, _cache_hits, _cache_misses
    _connolly_surface_cache.clear()
    _cache_hits = 0
    _cache_misses = 0
    log.info("🧹 Connolly surface cache cleared")

# Global cache for spatial indices to avoid rebuilding
_spatial_index_cache = {}


def _get_cached_spatial_index(atom_positions: np.ndarray, atom_colors: np.ndarray):
    """
    Get or create a cached spatial index for atom positions.
    This avoids rebuilding the index when atom positions haven't changed.
    """
    # Create a hash of the atom positions for caching
    positions_hash = hash(atom_positions.tobytes())

    if positions_hash in _spatial_index_cache:
        return _spatial_index_cache[positions_hash]

    try:
            from scipy.spatial import cKDTree

            atom_tree = cKDTree(atom_positions)
            _spatial_index_cache[positions_hash] = (atom_tree, atom_colors)
            return atom_tree, atom_colors
    except ImportError:
        return None, atom_colors
